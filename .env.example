# Copy this file to .env and fill in your values
# NEVER commit the real .env file — only .env.example

# Required — Google AI Studio API key (free tier at aistudio.google.com)
# Used for: SQL generation fallback + natural language explanations
GEMINI_API_KEY=your_gemini_api_key_here

# No other API keys needed!
# Embeddings run locally via all-MiniLM-L6-v2 ONNX (~22MB, downloaded on first run)

# Optional — set to 'prod' to use PostgreSQL instead of H2
SPRING_PROFILES_ACTIVE=dev

# Required only for prod profile
DATABASE_URL=jdbc:postgresql://localhost:5432/subscrub
